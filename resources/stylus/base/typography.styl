// Heading font
h1, h2, h3, h4, h5, h6
  font-family $font-heading
  color $color-dark

// Typographic scale
h1
  font-size 2.5rem
  font-weight 700

h2
  font-size 2rem
  font-weight 700

h3
  font-size 1.5rem
  font-weight 600

h4
  font-size 1.25rem
  font-weight 600

p
  font-size 1rem
  font-weight 400
  line-height 1.6
