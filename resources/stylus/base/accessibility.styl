// ── Global focus indicator ────────────────────────────────────────────────────
// Uses :focus-visible so mouse users don't see the ring, only keyboard users.
:focus-visible
  outline 3px solid $color-primary
  outline-offset 2px
  border-radius 2px

// Remove default :focus outline — replaced by :focus-visible above
:focus:not(:focus-visible)
  outline none


// ── Reduced motion ────────────────────────────────────────────────────────────
// Respects the OS-level "Reduce motion" preference.
// All animations and transitions are cut to near-zero duration.
@media (prefers-reduced-motion: reduce)
  *,
  *::before,
  *::after
    animation-duration 0.01ms !important
    animation-iteration-count 1 !important
    transition-duration 0.01ms !important
    scroll-behavior auto !important
