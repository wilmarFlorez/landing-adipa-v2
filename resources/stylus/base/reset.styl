// Box-sizing reset
*,
*::before,
*::after
  box-sizing border-box

// Margin and padding reset
*
  margin 0
  padding 0

// List reset
ul,
ol
  list-style none

// Button reset
button
  border none
  background none
  cursor pointer
  font inherit

// Input and textarea reset
input,
textarea,
select
  border none
  outline none
  font inherit
  background none

// Smooth scroll + prevent horizontal overflow on all viewports
html
  scroll-behavior smooth
  overflow-x hidden

body
  overflow-x hidden
