// Media query helper — min-width (mobile-first), accepts 'tablet' or 'desktop'
respond-to(breakpoint)
  if breakpoint == 'tablet'
    @media (min-width: $bp-tablet)
      {block}
  else if breakpoint == 'desktop'
    @media (min-width: $bp-desktop)
      {block}

// Max-width helper — use only for overlay/collapse patterns that require mobile-only scope
respond-below(breakpoint)
  if breakpoint == 'tablet'
    @media (max-width: ($bp-tablet - 1px))
      {block}
  else if breakpoint == 'desktop'
    @media (max-width: ($bp-desktop - 1px))
      {block}

// Flex center shorthand
flex-center()
  display flex
  align-items center
  justify-content center

// Multiline text truncation via webkit-line-clamp
truncate(lines)
  display -webkit-box
  -webkit-line-clamp lines
  -webkit-box-orient vertical
  overflow hidden

// Link style for dark-background sections (footer, dark panels)
// Repeated 3+ times in footer — extracted to eliminate duplication
dark-bg-link()
  color rgba($color-white, 0.7)
  text-decoration none
  transition color 0.2s ease

  &:hover
    color $color-secondary
