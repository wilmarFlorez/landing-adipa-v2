// Colors
$color-primary = #704EFD
$color-secondary = #2CB7FF
$color-pink = #FF017C
$color-orange = #FFA927
$color-dark = #3A3F5A
$color-light-bg = #F3F4FF
$color-light-bg-2 = #F8FAFF
$color-white = #FFFFFF

// Typography
$font-heading = 'Montserrat', sans-serif
$font-body = 'Poppins', sans-serif

// Spacing
$container-max-width = 1400px
$padding-global = 20px

// Border radius
$radius-card = 12px
$radius-btn = 8px

// Shadows
$shadow-card = 0 2px 4px rgba(3, 27, 78, 0.06)
$shadow-card-hover = 0 10px 20px rgba(3, 27, 78, 0.1)

// Breakpoints
$bp-mobile = 375px
$bp-tablet = 768px
$bp-desktop = 1280px
