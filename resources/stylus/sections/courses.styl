// Entrance animation — only transform + opacity so no layout shift occurs
@keyframes fadeInUp
  from
    opacity 0
    transform translateY(20px)
  to
    opacity 1
    transform translateY(0)


.s-courses
  padding 60px 0 // mobile

  +respond-to('tablet')
    padding 80px 0

  &__header
    text-align center
    margin-bottom 2rem

    h2
      color $color-dark
      margin-bottom 0.5rem

    ^[0]__subtitle
      color $color-gray-text
      font-size 1.125rem

  &__filters
    display flex
    flex-wrap wrap
    gap 0.75rem
    justify-content center
    margin-bottom 3rem

  &__grid
    display grid
    grid-template-columns 1fr
    gap 1.5rem

    +respond-to('sm')
      grid-template-columns repeat(2, 1fr)

    +respond-to('desktop')
      grid-template-columns repeat(3, 1fr)

  // Grid items — flex so .c-card stretches to match the tallest card in the row
  // Entrance animation is handled by JS (scroll-animations.js + .js-animate-on-scroll)
  &__item
    display flex

    &.is-hidden
      opacity 0
      pointer-events none
      position absolute
      visibility hidden

  &__empty
    text-align center
    color $color-gray-text
    font-size 1rem
    padding 2rem 0


// Filter pills — defined outside s-courses scope so they
// can be reused in other sections if needed
.c-filter-pill
  border 2px solid $color-primary
  color $color-primary
  background transparent
  border-radius 20px
  padding 8px 20px
  font-family $font-heading
  font-size 0.875rem
  font-weight 500
  cursor pointer
  transition background 0.2s ease, color 0.2s ease
  white-space nowrap

  &:hover:not(&--active)
    background rgba($color-primary, 0.08)

  &--active
    background $color-primary
    color $color-white
