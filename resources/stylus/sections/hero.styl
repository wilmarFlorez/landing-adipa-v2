.s-hero
  background linear-gradient(135deg, $color-primary 0%, $color-secondary 100%)
  min-height 400px
  display flex
  align-items center

  &__content
    flex-center()
    flex-direction column
    text-align center
    padding 60px 0
    width 100%

  &__title
    color $color-white
    font-size 2rem
    font-weight 700
    font-family $font-heading
    line-height 1.2
    margin-bottom 1rem
    max-width 700px

  &__subtitle
    color $color-white
    opacity 0.9
    font-size 1rem
    font-family $font-body
    max-width 600px
    margin-bottom 2rem
    line-height 1.6

  &__actions
    display flex
    flex-wrap wrap
    justify-content center
    gap 1rem

  // Outline button adapted for dark background
  &__btn-outline
    border-color $color-white !important
    color $color-white !important

    &:hover
      background rgba($color-white, 0.15) !important
      border-color $color-white !important
      color $color-white !important

  // Intermediate scale at 768px — avoids the 2rem→3rem jump
  +respond-to('tablet')
    &__title
      font-size 2.5rem

    &__subtitle
      font-size 1.125rem

  +respond-to('desktop')
    min-height 500px

    &__title
      font-size 3rem

    &__subtitle
      font-size 1.25rem

    &__actions
      flex-wrap nowrap
