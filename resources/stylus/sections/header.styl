.l-header
  position sticky
  top 0
  z-index 100
  background $color-white
  transition box-shadow 0.3s ease

  // Added via jQuery on scroll
  &--scrolled
    box-shadow $shadow-card

  &__inner
    display flex
    align-items center
    justify-content space-between
    height 70px

  &__logo
    font-family $font-heading
    font-weight 700
    font-size 1.5rem
    color $color-primary
    text-decoration none

    &:hover
      color darken($color-primary, 10%)

  &__nav-list
    display flex
    align-items center
    gap 2rem
    list-style none

  &__nav-link
    font-family $font-heading
    font-size 0.9375rem
    font-weight 500
    color $color-dark
    text-decoration none
    transition color 0.2s ease

    &:hover
      color $color-primary

  &__actions
    display flex
    align-items center
    gap 1rem

  // CTA inside nav — hidden on desktop, shown at bottom of mobile menu
  &__nav-cta
    display none

  // Hamburger button — hidden on desktop, shown on mobile
  &__burger
    display none
    flex-direction column
    justify-content center
    gap 5px
    width 36px
    height 36px
    padding 4px
    background none
    border none
    cursor pointer

  &__burger-bar
    display block
    width 100%
    height 2px
    background $color-dark
    border-radius 2px
    transition transform 0.3s ease, opacity 0.3s ease

  // Mobile-only styles — collapsed nav, burger menu, X animation
  // respond-below used here (not respond-to) because these styles must be
  // removed above the breakpoint, not added above it.
  +respond-below('tablet')
    &__nav
      position absolute
      top 70px
      left 0
      right 0
      background $color-white
      box-shadow $shadow-card

    &__nav-list
      flex-direction column
      align-items flex-start
      gap 0
      padding 0
      overflow hidden
      max-height 0
      transition max-height 0.35s ease, padding 0.35s ease

      // Open state — toggled by JS
      &.is-open
        max-height 300px
        padding 12px 0

    &__nav-link
      display block
      padding 12px 20px
      width 100%

    &__burger
      display flex

    &__actions
      gap 0.5rem

    // Hide desktop CTA — shown inside the nav list instead
    &__actions .c-btn
      display none

    // Show CTA as last nav item — full width
    &__nav-cta
      display block
      width 100%
      padding 8px 20px 12px

      .c-btn
        width 100%
        justify-content center

    // Burger → X animation when open (aria-expanded set by JS)
    // Max 2 BEM element levels: __burger → __burger-bar
    &__burger[aria-expanded='true'] &__burger-bar:nth-child(1)
      transform translateY(7px) rotate(45deg)

    &__burger[aria-expanded='true'] &__burger-bar:nth-child(2)
      opacity 0

    &__burger[aria-expanded='true'] &__burger-bar:nth-child(3)
      transform translateY(-7px) rotate(-45deg)
