.l-footer
  background $color-dark
  color rgba($color-white, 0.85)

  // ── Grid ────────────────────────────────────────────────────────────────────

  &__grid
    display grid
    grid-template-columns 1fr
    gap 2.5rem
    padding 60px 0

    +respond-to('tablet')
      grid-template-columns repeat(2, 1fr)

    +respond-to('desktop')
      grid-template-columns 2fr 1fr 1fr 1fr

  // ── Brand column ────────────────────────────────────────────────────────────

  &__logo
    display inline-block
    font-family $font-heading
    font-weight 700
    font-size 1.75rem
    color $color-white
    text-decoration none
    margin-bottom 1rem

    &:hover
      color $color-secondary

  &__brand-desc
    color rgba($color-white, 0.65)
    font-size 0.9rem
    line-height 1.7
    max-width 280px

  // ── Column titles ─────────────────────────────────────────────────────────

  &__col-title
    font-family $font-heading
    font-size 0.875rem
    font-weight 600
    color $color-white
    text-transform uppercase
    letter-spacing 0.05em
    margin-bottom 1rem

  // ── Nav links ────────────────────────────────────────────────────────────────
  // dark-bg-link() mixin handles: color, no-decoration, transition, hover color

  &__links
    list-style none
    display flex
    flex-direction column
    gap 0.5rem

    a
      dark-bg-link()
      font-size 0.9375rem

  // ── Social links ─────────────────────────────────────────────────────────────

  &__social
    list-style none
    display flex
    flex-direction column
    gap 0.5rem

    a
      display flex
      align-items center
      gap 0.5rem
      dark-bg-link()
      font-size 0.9375rem

      svg
        flex-shrink 0

  // ── Contact list ─────────────────────────────────────────────────────────────

  &__contact-list
    list-style none
    display flex
    flex-direction column
    gap 0.75rem

  &__contact-item
    display flex
    align-items center
    gap 0.5rem
    color rgba($color-white, 0.7)
    font-size 0.9375rem

    svg
      flex-shrink 0
      color rgba($color-white, 0.5)

    a
      dark-bg-link()

  // ── Bottom bar ───────────────────────────────────────────────────────────────

  &__bottom
    border-top 1px solid rgba($color-white, 0.1)
    padding 1.5rem 0
    display flex
    justify-content space-between
    align-items center
    flex-wrap wrap
    gap 1rem

  &__copyright
    font-size 0.875rem
    color rgba($color-white, 0.5)

  &__legal
    display flex
    gap 1.5rem
    flex-wrap wrap

    a
      font-size 0.875rem
      color rgba($color-white, 0.5)
      text-decoration none
      transition color 0.2s ease

      &:hover
        color rgba($color-white, 0.85)
