.c-form

  &__group
    margin-bottom 1.5rem

  &__label
    display block
    font-family $font-heading
    font-size 0.9375rem
    font-weight 500
    color $color-dark
    margin-bottom 6px

    span
      color #ef4444

  &__input
    width 100%
    padding 12px 16px
    border 2px solid #e5e7eb
    border-radius 8px
    font-family $font-body
    font-size 1rem
    color $color-dark
    background $color-white
    transition border-color 0.2s ease, box-shadow 0.2s ease
    appearance none

    &::placeholder
      color #9ca3af

    &:focus
      border-color $color-primary
      outline none
      box-shadow 0 0 0 3px rgba($color-primary, 0.15)

    // State modifiers — applied by JS
    &--error
      border-color #ef4444

      &:focus
        box-shadow 0 0 0 3px rgba(239, 68, 68, 0.15)

    &--valid
      border-color #22c55e

      &:focus
        box-shadow 0 0 0 3px rgba(34, 197, 94, 0.15)

    // Textarea variant
    &--textarea
      resize vertical
      min-height 130px

  &__error
    display block
    font-size 0.8rem
    color #ef4444
    margin-top 4px
    min-height 1.2em
    line-height 1.4

  &__submit
    width 100%
    justify-content center

  &__success
    text-align center
    padding 2.5rem 1.5rem
    color #16a34a

    svg
      margin-bottom 1rem
      color #22c55e

    p
      font-family $font-heading
      font-size 1.125rem
      font-weight 600
      color #16a34a
