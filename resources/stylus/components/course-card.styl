.c-card
  background $color-white
  border-radius $radius-card
  box-shadow $shadow-card
  overflow hidden
  display flex
  flex-direction column
  transition transform 0.2s ease, box-shadow 0.2s ease

  &:hover
    transform translateY(-4px)
    box-shadow $shadow-card-hover

  // Image area
  &__image-wrapper
    position relative
    overflow hidden
    aspect-ratio 3/2
    flex-shrink 0

  &__image
    width 100%
    height 100%
    object-fit cover
    display block
    transition transform 0.3s ease

  &:hover &__image
    transform scale(1.04)

  // Modality badge
  &__badge
    position absolute
    top 12px
    left 12px
    padding 4px 10px
    border-radius 20px
    color $color-white
    font-family $font-heading
    font-size 0.75rem
    font-weight 600
    line-height 1.4
    letter-spacing 0.02em

  // Card body
  &__body
    padding 20px
    display flex
    flex-direction column
    flex-grow 1
    gap 10px

  &__title
    font-family $font-heading
    font-size 1rem
    font-weight 600
    color $color-dark
    line-height 1.4
    min-height 2.8rem  // 1rem × 1.4 × 2 lines — aligns elements across cards
    truncate(2)

  &__instructor,
  &__date
    display flex
    align-items center
    gap 6px
    font-size 0.875rem
    color $color-gray-text
    font-family $font-body
    line-height 1.4

    svg
      flex-shrink 0
      color $color-gray-muted

  // Pricing row
  &__pricing
    display flex
    align-items center
    gap 8px
    margin-top auto

  &__price-original
    font-size 0.875rem
    color $color-gray-muted
    text-decoration line-through
    font-family $font-body

  &__price-discount
    font-family $font-heading
    font-size 1.125rem
    font-weight 700
    color $color-pink

  // CTA button — full-width at bottom of card
  &__cta
    width 100% !important
    margin-top 4px
    justify-content center
